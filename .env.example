# =============================================================================
# POLYHARMONY CALENDAR - ENVIRONMENT CONFIGURATION
# =============================================================================
# This file contains all environment variables needed for the application.
# Copy this file to create your environment-specific configurations:
# - .env.local (development overrides)
# - .env (base configuration)
# - .env.production (production settings)

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_TELEMETRY_DISABLED=1

# Security Profile (development, staging, production, demo)
SECURITY_PROFILE=development

# =============================================================================
# SUPABASE DATABASE (REQUIRED)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# SECURITY & ENCRYPTION (REQUIRED)
# =============================================================================
# CRITICAL: This must be a 64-character hex string for AES-256 encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-encryption-key-here

# Additional security keys (regenerate for production)
KEY_DERIVATION_SECRET=your-128-character-key-derivation-secret
JWT_SECRET=your-base64-jwt-secret
NEXTAUTH_SECRET=your-base64-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# EMAIL CONFIGURATION (REQUIRED)
# =============================================================================
# Choose ONE email service provider:

# Option 1: Resend (Recommended for production)
RESEND_API_KEY=your-resend-api-key

# Option 2: SendGrid
# SENDGRID_API_KEY=your-sendgrid-api-key

# Option 3: AWS SES
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1

# Option 4: SMTP
# SMTP_HOST=your-smtp-host
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password

# Email Sender Configuration
INVITATION_FROM_EMAIL=invites@polyharmony.app
INVITATION_FROM_NAME=PolyHarmony

# =============================================================================
# CALENDAR INTEGRATIONS (OPTIONAL)
# =============================================================================
# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/oauth/callback

# Apple Calendar (CalDAV)
# ICLOUD_USERNAME=your-icloud-email
# ICLOUD_APP_PASSWORD=your-app-specific-password

# =============================================================================
# FEATURE FLAGS
# =============================================================================
FEATURE_GOOGLE_CALENDAR=false
FEATURE_EMAIL_NOTIFICATIONS=true
NEXT_PUBLIC_DEV_AUTH_BYPASS=true
ENABLE_DEBUG_LOGGING=true
SKIP_EMAIL_VERIFICATION=false

# =============================================================================
# PERFORMANCE & MONITORING
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000
LOG_LEVEL=debug

# =============================================================================
# MOBILE & PWA
# =============================================================================
NEXT_PUBLIC_APP_SCHEME=polyharmony
NEXT_PUBLIC_MOBILE_APP_URL=polyharmony://
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000

# =============================================================================
# DATABASE (OPTIONAL - for direct connections)
# =============================================================================
DATABASE_URL=your-database-url

# =============================================================================
# DEVELOPMENT ONLY SETTINGS
# =============================================================================
# These should be disabled/removed in production
ENABLE_DEMO_MODE=false
DEMO_MODE=true