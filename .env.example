# MyOrbit Environment Configuration
# Copy this file to .env and fill in your actual values

# ========================================
# ENVIRONMENT SELECTION
# ========================================
# Set the active environment (dev, staging, or prod)
# This controls which Firebase project and backend services are used
APP_ENV=dev

# FLUTTER_ENV is deprecated - use APP_ENV instead
# Kept for backwards compatibility during migration
FLUTTER_ENV=dev

# ========================================
# SUPABASE CONFIGURATION (LEGACY)
# ========================================
# Note: Being replaced with Firebase during migration
# These will be removed once Firebase migration is complete

# Development Environment
DEV_SUPABASE_URL=your-dev-supabase-url-here
DEV_SUPABASE_ANON_KEY=your-dev-supabase-anon-key-here

# Staging Environment
STAGING_SUPABASE_URL=your-staging-supabase-url-here
STAGING_SUPABASE_ANON_KEY=your-staging-supabase-anon-key-here

# Production Environment
PROD_SUPABASE_URL=your-prod-supabase-url-here
PROD_SUPABASE_ANON_KEY=your-prod-supabase-anon-key-here

# ========================================
# FIREBASE CONFIGURATION
# ========================================
# Firebase configuration is managed through firebase_options_*.dart files
# Generate these files using:
# fvm flutterfire configure --project=myorbit-[env] --out=lib/core/firebase_options_[env].dart
#
# No Firebase credentials are needed in this .env file - they're in the generated files

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID_IOS=your-google-oauth-client-id-ios-here
GOOGLE_OAUTH_CLIENT_ID_ANDROID=your-google-oauth-client-id-android-here

# Apple Sign-In
APPLE_SERVICES_ID=your-apple-services-id-here

# Sentry Error Tracking
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENV=development
SENTRY_RELEASE=myorbit@1.0.0+1

# Twilio SMS (for future AI features - not needed for MVP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
