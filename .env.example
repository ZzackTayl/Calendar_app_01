# MyOrbit Environment Configuration
# Copy this file to .env and fill in your actual values

# Supabase Configuration
SUPABASE_URL=your-supabase-url-here
SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Firebase Cloud Messaging (for push notifications - optional for MVP)
FCM_SERVER_KEY=your-fcm-server-key-here

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID_IOS=your-google-oauth-client-id-ios-here
GOOGLE_OAUTH_CLIENT_ID_ANDROID=your-google-oauth-client-id-android-here

# Apple Sign-In
APPLE_SERVICES_ID=your-apple-services-id-here

# Sentry Error Tracking (optional)
SENTRY_DSN=your-sentry-dsn-here
SENTRY_ENV=development
SENTRY_RELEASE=myorbit@1.0.0+1

# Twilio SMS (for future AI features - not needed for MVP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
