# Security Configuration for Key Derivation
# Copy this to your .env.local and customize for your environment

# ======================
# Key Derivation Settings
# ======================

# Primary secret for key derivation (CRITICAL - CHANGE IN PRODUCTION)
# Must be a strong, randomly generated secret
# Generate with: openssl rand -hex 64
KEY_DERIVATION_SECRET=development-secret

# Key derivation algorithm: argon2id, scrypt, or pbkdf2
# argon2id is recommended for production (winner of password hashing competition)
KEY_DERIVATION_ALGORITHM=argon2id

# Security level: development, testing, production, high_security
# Controls iteration counts, memory usage, and computational cost
SECURITY_LEVEL=development

# Browser encryption security level (for client-side encryption)
# Options: development, testing, production, high_security
NEXT_PUBLIC_SECURITY_LEVEL=production

# ======================
# Production Security Notes
# ======================

# FOR PRODUCTION DEPLOYMENT:
# 1. Generate a new KEY_DERIVATION_SECRET:
#    openssl rand -hex 64
# 
# 2. Set SECURITY_LEVEL=production
# 
# 3. Set KEY_DERIVATION_ALGORITHM=argon2id
#
# 4. Consider using environment-specific secrets management:
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Azure Key Vault
#    - Google Secret Manager

# ======================
# Performance Tuning
# ======================

# High-security environments (government, healthcare, finance):
# SECURITY_LEVEL=high_security
# This uses maximum security parameters but will be slower

# Development/Testing:
# SECURITY_LEVEL=development
# This uses faster parameters for development speed

# ======================
# Hardware Considerations
# ======================

# Argon2 Memory Requirements by Security Level:
# - development: 4 MB RAM per derivation
# - testing: 8 MB RAM per derivation  
# - production: 64 MB RAM per derivation
# - high_security: 128 MB RAM per derivation

# For high-traffic applications, monitor memory usage and consider:
# 1. Scaling up server memory
# 2. Using scrypt instead of Argon2 if memory-constrained
# 3. Implementing rate limiting on authentication endpoints

# ======================
# Security Monitoring
# ======================

# Enable security monitoring in production:
# - Log key derivation timing (detect timing attacks)
# - Monitor failed authentication attempts
# - Alert on unusual patterns or performance degradation

# Example monitoring environment variables:
# ENABLE_SECURITY_MONITORING=true
# SECURITY_LOG_LEVEL=info
# MAX_AUTH_ATTEMPTS_PER_IP=5
# AUTH_RATE_LIMIT_WINDOW=900000
