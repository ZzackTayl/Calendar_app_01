name: Security Tests

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main, develop ]
  schedule:
    # Run security tests daily at 2 AM UTC
    - cron: '0 2 * * *'

permissions:
  contents: read
  security-events: write
  actions: read
  pull-requests: write

jobs:
  security-tests:
    runs-on: ubuntu-latest
    
    steps:
    - name: Checkout code
      uses: actions/checkout@v4
      
    - name: Use Node.js 20.x
      uses: actions/setup-node@v4
      with:
        node-version: 20.x
        cache: 'npm'
        
    - name: Install dependencies
      run: npm ci
      
    - name: Create test environment file
      run: |
        cat > .env.test << EOF
        NODE_ENV=test
        NEXT_PUBLIC_SUPABASE_URL=https://test.supabase.co
        NEXT_PUBLIC_SUPABASE_ANON_KEY=test-anon-key
        SUPABASE_SERVICE_ROLE_KEY=test-service-role-key
        NEXTAUTH_SECRET=test-secret-key-that-is-at-least-32-characters-long
        NEXTAUTH_URL=https://test.example.com
        ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
        EOF
        
    - name: Load test environment
      run: |
        export $(cat .env.test | xargs)
        echo "Environment variables loaded for testing"
        
    - name: Run security configuration validation
      run: |
        export $(cat .env.test | xargs)
        npm run security:validate
      env:
        NODE_ENV: test
        NEXT_PUBLIC_SUPABASE_URL: https://test.supabase.co
        NEXT_PUBLIC_SUPABASE_ANON_KEY: test-anon-key
        SUPABASE_SERVICE_ROLE_KEY: test-service-role-key
        NEXTAUTH_SECRET: test-secret-key-that-is-at-least-32-characters-long
        NEXTAUTH_URL: https://test.example.com
        ENCRYPTION_KEY: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
        
    - name: Run TypeScript strict mode check
      run: npx tsc --noEmit --strict
      
    - name: Run ESLint security rules
      run: npx eslint --ext .ts,.tsx --config .eslintrc.json .
      continue-on-error: true
      
    - name: Run dependency security audit
      run: npm audit --audit-level=moderate
      continue-on-error: true
      
    - name: Run security unit tests
      run: |
        export $(cat .env.test | xargs)
        npm test -- __tests__/auth-bypass-prevention.test.ts --run
        npm test -- __tests__/session-validation-integration.test.ts --run
        npm test -- __tests__/security-monitoring.test.ts --run
      env:
        NODE_ENV: test
        NEXT_PUBLIC_SUPABASE_URL: https://test.supabase.co
        NEXT_PUBLIC_SUPABASE_ANON_KEY: test-anon-key
        SUPABASE_SERVICE_ROLE_KEY: test-service-role-key
        NEXTAUTH_SECRET: test-secret-key-that-is-at-least-32-characters-long
        NEXTAUTH_URL: https://test.example.com
        ENCRYPTION_KEY: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
        
    - name: Run security integration tests
      run: |
        export $(cat .env.test | xargs)
        npm test -- __tests__/security-integration.test.ts --run
        npm test -- __tests__/security-monitoring-validation.test.ts --run
      env:
        NODE_ENV: test
        NEXT_PUBLIC_SUPABASE_URL: https://test.supabase.co
        NEXT_PUBLIC_SUPABASE_ANON_KEY: test-anon-key
        SUPABASE_SERVICE_ROLE_KEY: test-service-role-key
        NEXTAUTH_SECRET: test-secret-key-that-is-at-least-32-characters-long
        NEXTAUTH_URL: https://test.example.com
        ENCRYPTION_KEY: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
        
    - name: Run comprehensive security test suite
      run: |
        export $(cat .env.test | xargs)
        npm run security:test
      env:
        NODE_ENV: test
        NEXT_PUBLIC_SUPABASE_URL: https://test.supabase.co
        NEXT_PUBLIC_SUPABASE_ANON_KEY: test-anon-key
        SUPABASE_SERVICE_ROLE_KEY: test-service-role-key
        NEXTAUTH_SECRET: test-secret-key-that-is-at-least-32-characters-long
        NEXTAUTH_URL: https://test.example.com
        ENCRYPTION_KEY: 0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
        
    - name: Upload security test report
      uses: actions/upload-artifact@v4
      if: always()
      with:
        name: security-test-report
        path: security-test-report.json
        
    - name: Comment security results on PR
      if: github.event_name == 'pull_request' && always()
      uses: actions/github-script@v7
      with:
        script: |
          const fs = require('fs');
          
          try {
            const report = JSON.parse(fs.readFileSync('security-test-report.json', 'utf8'));
            
            const summary = report.summary;
            const status = summary.success ? '✅ PASSED' : '❌ FAILED';
            const emoji = summary.success ? '🔒' : '🚨';
            
            const body = `
          ## ${emoji} Security Test Results ${status}
          
          **Summary:**
          - Total Tests: ${summary.totalTests}
          - Passed: ${summary.passed}
          - Failed: ${summary.failed}
          - Warnings: ${summary.warnings}
          - Duration: ${Math.round(summary.duration / 1000)}s
          
          ${summary.requiredFailed > 0 ? `**❌ ${summary.requiredFailed} required security tests failed - deployment blocked**` : ''}
          
          **Recommendations:**
          ${report.recommendations.map(rec => `- ${rec}`).join('\n')}
          
          <details>
          <summary>Detailed Results</summary>
          
          ${report.results.map(result => 
            `- ${result.status === 'pass' ? '✅' : result.status === 'fail' ? '❌' : '⚠️'} **${result.category}**: ${result.testName} - ${result.message}`
          ).join('\n')}
          
          </details>
          `;
          
            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: body
            });
          } catch (error) {
            console.log('Could not read security test report:', error.message);
          }

  production-security-validation:
    runs-on: ubuntu-latest
    if: github.ref == 'refs/heads/main' && github.event_name != 'pull_request'
    
    steps:
    - name: Checkout code
      uses: actions/checkout@v4
      
    - name: Use Node.js 20.x
      uses: actions/setup-node@v4
      with:
        node-version: 20.x
        cache: 'npm'
        
    - name: Install dependencies
      run: npm ci
      
    - name: Check if production secrets are available
      id: check-secrets
      run: |
        if [ -z "${{ secrets.NEXT_PUBLIC_SUPABASE_URL }}" ]; then
          echo "Production secrets not configured - skipping production validation"
          echo "secrets-available=false" >> $GITHUB_OUTPUT
        else
          echo "Production secrets available - proceeding with validation"
          echo "secrets-available=true" >> $GITHUB_OUTPUT
        fi
        
    - name: Create production environment file
      if: steps.check-secrets.outputs.secrets-available == 'true'
      run: |
        cat > .env.production << EOF
        NODE_ENV=production
        NEXT_PUBLIC_SUPABASE_URL=${{ secrets.NEXT_PUBLIC_SUPABASE_URL }}
        NEXT_PUBLIC_SUPABASE_ANON_KEY=${{ secrets.NEXT_PUBLIC_SUPABASE_ANON_KEY }}
        SUPABASE_SERVICE_ROLE_KEY=${{ secrets.SUPABASE_SERVICE_ROLE_KEY }}
        NEXTAUTH_SECRET=${{ secrets.NEXTAUTH_SECRET }}
        NEXTAUTH_URL=${{ secrets.NEXTAUTH_URL }}
        ENCRYPTION_KEY=${{ secrets.ENCRYPTION_KEY }}
        EOF
      
    - name: Validate production security configuration
      if: steps.check-secrets.outputs.secrets-available == 'true'
      run: npm run security:init
      env:
        NODE_ENV: production
        
    - name: Run production security tests
      if: steps.check-secrets.outputs.secrets-available == 'true'
      run: npm run security:test
      env:
        NODE_ENV: production
        
    - name: Skip production validation (secrets not configured)
      if: steps.check-secrets.outputs.secrets-available == 'false'
      run: |
        echo "⚠️ Production secrets not configured in GitHub repository"
        echo "To enable production security validation, add the following secrets:"
        echo "- NEXT_PUBLIC_SUPABASE_URL"
        echo "- NEXT_PUBLIC_SUPABASE_ANON_KEY" 
        echo "- SUPABASE_SERVICE_ROLE_KEY"
        echo "- NEXTAUTH_SECRET"
        echo "- NEXTAUTH_URL"
        echo "- ENCRYPTION_KEY"
        echo ""
        echo "For now, skipping production validation and using test configuration."
        
    - name: Create deployment security report
      if: always()
      run: |
        echo "# Production Security Validation Report" > security-deployment-report.md
        echo "" >> security-deployment-report.md
        echo "**Date:** $(date)" >> security-deployment-report.md
        echo "**Commit:** ${{ github.sha }}" >> security-deployment-report.md
        echo "**Branch:** ${{ github.ref_name }}" >> security-deployment-report.md
        echo "" >> security-deployment-report.md
        
        if [ -f security-test-report.json ]; then
          echo "**Security Test Results:**" >> security-deployment-report.md
          node -e "
            const report = JSON.parse(require('fs').readFileSync('security-test-report.json', 'utf8'));
            console.log(\`- Total Tests: \${report.summary.totalTests}\`);
            console.log(\`- Passed: \${report.summary.passed}\`);
            console.log(\`- Failed: \${report.summary.failed}\`);
            console.log(\`- Success: \${report.summary.success ? 'YES' : 'NO'}\`);
          " >> security-deployment-report.md
        fi
        
    - name: Upload production security report
      uses: actions/upload-artifact@v4
      if: always()
      with:
        name: production-security-report
        path: |
          security-test-report.json
          security-deployment-report.md

  dependency-security-scan:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      security-events: write
    
    steps:
    - name: Checkout code
      uses: actions/checkout@v4
      
    - name: Run Trivy vulnerability scanner
      uses: aquasecurity/trivy-action@master
      with:
        scan-type: 'fs'
        scan-ref: '.'
        format: 'sarif'
        output: 'trivy-results.sarif'
      continue-on-error: true
        
    - name: Upload Trivy scan results to GitHub Security tab
      uses: github/codeql-action/upload-sarif@v3
      if: always() && github.event_name != 'pull_request'
      with:
        sarif_file: 'trivy-results.sarif'
      continue-on-error: true
      
    - name: Upload Trivy results as artifact (for PRs)
      uses: actions/upload-artifact@v4
      if: always() && github.event_name == 'pull_request'
      with:
        name: trivy-security-scan
        path: trivy-results.sarif
        
    - name: Run npm audit
      run: |
        npm audit --audit-level=moderate --json > npm-audit-results.json || true
        
    - name: Process npm audit results
      run: |
        if [ -f npm-audit-results.json ]; then
          echo "# NPM Security Audit Results" > npm-audit-summary.md
          echo "" >> npm-audit-summary.md
          
          # Check if jq is available
          if command -v jq &> /dev/null; then
            # Extract vulnerability counts using jq
            CRITICAL=$(cat npm-audit-results.json | jq -r '.metadata.vulnerabilities.critical // 0' 2>/dev/null || echo "0")
            HIGH=$(cat npm-audit-results.json | jq -r '.metadata.vulnerabilities.high // 0' 2>/dev/null || echo "0")
            MODERATE=$(cat npm-audit-results.json | jq -r '.metadata.vulnerabilities.moderate // 0' 2>/dev/null || echo "0")
            LOW=$(cat npm-audit-results.json | jq -r '.metadata.vulnerabilities.low // 0' 2>/dev/null || echo "0")
          else
            # Fallback without jq
            echo "jq not available, using basic parsing"
            CRITICAL=$(grep -o '"critical":[0-9]*' npm-audit-results.json | cut -d':' -f2 || echo "0")
            HIGH=$(grep -o '"high":[0-9]*' npm-audit-results.json | cut -d':' -f2 || echo "0")
            MODERATE=$(grep -o '"moderate":[0-9]*' npm-audit-results.json | cut -d':' -f2 || echo "0")
            LOW=$(grep -o '"low":[0-9]*' npm-audit-results.json | cut -d':' -f2 || echo "0")
          fi
          
          echo "- Critical: $CRITICAL" >> npm-audit-summary.md
          echo "- High: $HIGH" >> npm-audit-summary.md
          echo "- Moderate: $MODERATE" >> npm-audit-summary.md
          echo "- Low: $LOW" >> npm-audit-summary.md
          
          echo "NPM Audit Results:"
          echo "- Critical: $CRITICAL"
          echo "- High: $HIGH"
          echo "- Moderate: $MODERATE"
          echo "- Low: $LOW"
          
          # Only warn about critical or high vulnerabilities, don't fail the build
          if [ "$CRITICAL" -gt 0 ] || [ "$HIGH" -gt 0 ]; then
            echo "⚠️ Critical or high severity vulnerabilities found"
            echo "Please review and update dependencies"
          else
            echo "✅ No critical or high severity vulnerabilities found"
          fi
        else
          echo "No npm audit results file found"
          echo "- Status: No vulnerabilities detected" >> npm-audit-summary.md
        fi
        
    - name: Upload dependency scan results
      uses: actions/upload-artifact@v4
      if: always()
      with:
        name: dependency-security-scan
        path: |
          npm-audit-results.json
          npm-audit-summary.md