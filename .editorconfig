root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{js,jsx,ts,tsx,json,css,scss,md,yml,yaml}]
indent_size = 2

[*.{html,xml}]
indent_size = 2

[*.py]
indent_size = 4

[*.{sh,bash}]
end_of_line = lf

[*.{md,txt}]
trim_trailing_whitespace = false

[package.json]
indent_size = 2