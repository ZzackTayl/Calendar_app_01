# Disable External Services in Tests
DISABLE_EXTERNAL_APIS=true
DISABLE_EMAIL_SENDING=true
DISABLE_SMS_SENDING=true
DISABLE_PUSH_NOTIFICATIONS=true

# Test Rate Limiting (More permissive for testing)
RATE_LIMIT_AUTH_REQUESTS=50
RATE_LIMIT_AUTH_WINDOW_MINUTES=15
RATE_LIMIT_API_REQUESTS=500
RATE_LIMIT_API_WINDOW_MINUTES=60
RATE_LIMIT_EVENTS_REQUESTS=100
RATE_LIMIT_EVENTS_WINDOW_MINUTES=60

# Test Email Configuration (Mock)
EMAIL_PROVIDER=mock
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=test@example.com
SMTP_PASS=testpassword
EMAIL_FROM=noreply@test.polyharmony.com

# Test Storage Configuration
STORAGE_PROVIDER=local
STORAGE_LOCAL_PATH=/tmp/polyharmony-test-storage

# Test Monitoring (Disabled)
DISABLE_MONITORING=true
DISABLE_ANALYTICS=true
DISABLE_ERROR_REPORTING=true

# Test-specific Feature Flags
ENABLE_DEBUG_LOGGING=true
ENABLE_TEST_HELPERS=true
SKIP_EMAIL_VERIFICATION=true
