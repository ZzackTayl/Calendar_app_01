# Environment Variables for Local Development
# Copy this file to .env.local and fill in the actual values
# NEVER commit real credentials to version control

# =============================================================================
# REQUIRED CONFIGURATION
# =============================================================================

# Supabase Configuration
# Get these values from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Security Configuration (CRITICAL FOR PRODUCTION)
ENCRYPTION_KEY=your-32-character-encryption-key-here
NEXTAUTH_SECRET=your-nextauth-secret-key-minimum-32-chars
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================

# Google Calendar API Credentials
# Required only if using Google Calendar integration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# SMS/Twilio Configuration
# Required only if using SMS notifications
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890
# SMS_PROVIDER options: twilio, console, mock (default: console for development)
SMS_PROVIDER=console

# Service Role Key (for server-side operations)
# Use with extreme caution - has admin privileges
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================

# SMTP Configuration for email notifications
# SMTP_HOST=your-smtp-host.com
# SMTP_PORT=587
# SMTP_USER=your-email@domain.com
# SMTP_PASSWORD=your-smtp-password

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
FEATURE_GOOGLE_CALENDAR=false
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_SMS_NOTIFICATIONS=false

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Supabase Auth Configuration
# OTP_EXPIRY_DURATION=600  # 10 minutes in seconds (configure in Supabase dashboard)
# PASSWORD_MIN_LENGTH=12   # Minimum password length
# MFA_ENABLED=true        # Enable Multi-Factor Authentication

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# Environment
NODE_ENV=development

# Disable Next.js telemetry for privacy
NEXT_TELEMETRY_DISABLED=1

# Bundle analyzer (set to 'true' to analyze bundle size)
# ANALYZE=false