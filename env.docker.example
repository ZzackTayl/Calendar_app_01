# PolyHarmony Calendar - Docker Development Environment
# Copy this file to .env.local for Docker development

# =============================================================================
# REQUIRED FOR DOCKER DEVELOPMENT
# =============================================================================

# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WEB_APP_URL=http://localhost:3000

# Database Configuration (Docker uses local PostgreSQL)
DATABASE_URL=postgresql://postgres:password@db:5432/polyharmony_dev

# Supabase Configuration (Docker development overrides)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:3000/api/auth
NEXT_PUBLIC_SUPABASE_ANON_KEY=dev_anon_key_for_docker
SUPABASE_SERVICE_ROLE_KEY=dev_service_key_for_docker

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================

# Skip environment validation for Docker development
SKIP_ENV_VALIDATION=true

# Disable telemetry
NEXT_TELEMETRY_DISABLED=1

# Development mode
NODE_ENV=development

# =============================================================================
# OPTIONAL: EMAIL TESTING (MailHog)
# =============================================================================

# Email configuration for testing
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# =============================================================================
# OPTIONAL: REDIS CACHING
# =============================================================================

# Redis configuration
REDIS_URL=redis://redis:6379

# =============================================================================
# NOTES FOR BEGINNERS
# =============================================================================

# 1. Copy this file: cp env.docker.example .env.local
# 2. Start Docker: docker-compose -f docker-compose.simple.yml up
# 3. Access your app: http://localhost:3000
# 4. View emails: http://localhost:8025 (MailHog)
# 5. Database: localhost:5432 (PostgreSQL)
# 6. Cache: localhost:6379 (Redis)
