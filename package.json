{
  "name": "nextjs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "ANALYZE=true next build",
    "type-check": "tsc --noEmit",
    "performance": "npm run build && npm run start",
    "swarm:preload": "npx ruv-swarm hook pre-operation --preload-wasm --modules swarm,persistence",
    "swarm:optimize": "npx ruv-swarm benchmark run --type wasm --iterations 3",
    "swarm:monitor": "npx ruv-swarm monitor --duration 300 --export-metrics",
    "neural:init": "node -e \"import('./config/neural-initialization.js').then(m => m.neuralSystemInitializer.initialize())\"",
    "neural:status": "node -e \"import('./config/neural-initialization.js').then(m => console.log(JSON.stringify(m.neuralSystemInitializer.getSystemStatus(), null, 2)))\"",
    "neural:models": "node -e \"import('./config/neural-models.js').then(m => console.log('Available models:', Object.keys(m.NEURAL_MODELS)))\"",
    "neural:agents": "node -e \"import('./config/agent-archetypes.js').then(m => console.log('Available agents:', Object.keys(m.AGENT_ARCHETYPES)))\"",
    "neural:benchmark": "npx ruv-swarm neural train --iterations 5 && npx ruv-swarm benchmark run --type neural",
    "neural:patterns": "npx ruv-swarm neural patterns --pattern all",
    "predev": "npm run swarm:preload && npm run neural:init",
    "prebuild": "npm run swarm:optimize && npm run neural:benchmark",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "npm run lint && npm run type-check && npm run test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.1",
    "@next/swc-wasm-nodejs": "13.5.1",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@supabase/auth-helpers-nextjs": "^0.10.0",
    "@supabase/supabase-js": "^2.53.0",
    "@types/node": "20.6.2",
    "@types/react": "18.2.22",
    "@types/react-dom": "18.2.7",
    "autoprefixer": "10.4.15",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.1",
    "embla-carousel-react": "^8.3.0",
    "eslint": "8.49.0",
    "eslint-config-next": "13.5.1",
    "input-otp": "^1.2.4",
    "lucide-react": "^0.446.0",
    "next": "^14.2.3",
    "next-themes": "^0.3.0",
    "postcss": "8.4.30",
    "react": "18.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.62.0",
    "react-resizable-panels": "^2.1.3",
    "recharts": "^2.12.7",
    "rrule": "^2.8.1",
    "sonner": "^1.5.0",
    "spacetime": "^7.10.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "3.3.3",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.2.2",
    "vaul": "^0.9.9",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.3",
    "@testing-library/react": "^14.1.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@vitest/coverage-v8": "^1.2.1",
    "critters": "^0.0.23",
    "jsdom": "^24.0.0",
    "vitest": "^1.2.1"
  }
}
