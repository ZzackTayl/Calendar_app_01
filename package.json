
{
  "name": "polyharmony-calendar",
  "version": "1.0.0-alpha.1",
  "private": true,
  "description": "A privacy-first, neurodiversity-affirming calendar application designed for polyamorous relationships with enhanced conflict detection and multi-partner scheduling.",
  "keywords": [
    "calendar",
    "polyamory",
    "privacy",
    "scheduling",
    "nextjs",
    "typescript",
    "supabase",
    "neurodiversity-affirming",
    "conflict-detection",
    "multi-partner"
  ],
  "author": "PolyHarmony Development Team",
  "license": "MIT",
  "homepage": "https://polyharmony.calendar",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/polyharmony-calendar.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/polyharmony-calendar/issues"
  },
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run lint:cached && npm run type-check",
    "build": "cross-env RUNTIME_SKIP_AUTOSTART=1 NODE_OPTIONS=\"--max-old-space-size=6144 --max-semi-space-size=512\" next build --no-lint",
    "build:simple": "next build",
    "build:fast": "cross-env RUNTIME_SKIP_AUTOSTART=1 NODE_ENV=production NODE_OPTIONS=\"--max-old-space-size=6144\" next build --experimental-build-mode=compile",
    "start": "next start",
    "lint": "next lint",
    "lint:cached": "eslint --cache --cache-location .cache/eslint/.eslintcache app components hooks lib middleware.ts",
    "analyze": "cross-env ANALYZE=true next build",
    "type-check": "tsc --noEmit --incremental",
    "type-check:fast": "tsc --noEmit --incremental --skipLibCheck",
    "performance": "npm run build && npm run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare:test-env": "npx tsx scripts/prepare-test-secrets.ts",
    "pretest": "npm run prepare:test-env",
    "pretest:watch": "npm run prepare:test-env",
    "pretest:ci": "npm run prepare:test-env",
    "pretest:unit": "npm run prepare:test-env",
    "pretest:unit:watch": "npm run prepare:test-env",
    "pretest:integration": "npm run prepare:test-env",
    "pretest:integration:watch": "npm run prepare:test-env",
    "pretest:all": "npm run prepare:test-env",
    "test:ci": "vitest run --watch=false --run",
    "test:unit": "cross-env TEST_TYPE=unit vitest run",
    "test:unit:watch": "cross-env TEST_TYPE=unit vitest",
    "test:unit:coverage": "cross-env TEST_TYPE=unit vitest run --coverage",
    "test:integration": "cross-env TEST_TYPE=integration vitest run",
    "test:integration:watch": "cross-env TEST_TYPE=integration vitest",
    "test:integration:coverage": "cross-env TEST_TYPE=integration vitest run --coverage",
    "test:contracts": "cross-env TEST_TYPE=contract vitest run tests/contracts/**/*.test.ts",
    "test:contracts:consumers": "cross-env TEST_TYPE=contract vitest run tests/contracts/**/**.consumer.test.ts",
    "test:contracts:providers": "cross-env TEST_TYPE=contract vitest run tests/contracts/**/**.provider.test.ts",
    "test:contracts:auth": "cross-env TEST_TYPE=contract vitest run tests/contracts/auth/**/*.test.ts",
    "test:contracts:events": "cross-env TEST_TYPE=contract vitest run tests/contracts/events/**/*.test.ts",
    "test:contracts:calendar": "cross-env TEST_TYPE=contract vitest run tests/contracts/calendar/**/*.test.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "validate": "npm run lint && npm run type-check && npm run test:unit",
    "validate:full": "npm run lint && npm run type-check && npm run test:all",
    "validate:pwa": "node scripts/validate-pwa.js",
    "validate:schema": "node scripts/validate-database-schema.js",
    "alpha:test:prepare": "node scripts/prepare-alpha-test.js",
    "alpha:test:cleanup": "node scripts/cleanup-alpha-test.js",
    "alpha:test:invitation": "node scripts/test-invitation-system.js",
    "alpha:test:email": "node scripts/test-email-system.js",
    "alpha:test:verify": "node scripts/verify-alpha-setup.js",
    "alpha:apply:migration": "node scripts/apply-invitation-migration.js",
    "alpha:setup:env": "node scripts/setup-env-variables.js",
    "test:calendar": "node scripts/test-calendar-integrations.js",
    "test:account-deletion": "node scripts/test-account-deletion.js",
    "db:apply-schema-fix": "node scripts/apply-unified-schema.js",
    "db:verify-schema": "node scripts/verify-schema.js",
    "db:test-api": "node scripts/test-api-endpoints.js",
    "api:discover": "node scripts/discover-api-endpoints.js",
    "api:test": "node scripts/test-api-endpoints.js",
    "api:test:verbose": "node scripts/test-api-endpoints.js --verbose",
    "api:validate": "npm run api:discover && npm run api:test",
    "api:migrate": "node scripts/migrate-api-endpoints.js",
    "api:migrate:priority": "node scripts/migrate-api-endpoints.js --priority",
    "api:fix": "npm run api:migrate:priority && npm run api:test",
    "db:push": "npx supabase db push",
    "db:reset": "npx supabase db reset",
    "fix:group-permissions": "node scripts/apply-group-permissions-fix.js",
    "backup:validate": "node scripts/backup-validation.js",
    "backup:create": "./scripts/backup-application.sh",
    "test:upload": "node scripts/test-upload.js ./sample-files/test.pdf",
    "monitoring:check": "node scripts/monitoring-alerts.js --check-once",
    "monitoring:start": "node scripts/monitoring-alerts.js",
    "test:db:setup": "docker-compose -f docker-compose.test.yml up -d test-db",
    "test:db:teardown": "docker-compose -f docker-compose.test.yml down -v",
    "test:db:reset": "docker-compose -f docker-compose.test.yml restart test-db",
    "test:db:logs": "docker-compose -f docker-compose.test.yml logs test-db",
    "test:db:seed": "npx tsx tests/db/scripts/seed.ts",
    "test:db:clean": "npx tsx tests/db/scripts/clean.ts",
    "test:db:validate": "npx tsx tests/db/scripts/validate.ts",
    "test:db:schema": "npx tsx tests/db/scripts/schema-test.ts",
    "test:db:types": "npx tsx tests/db/scripts/type-check.ts",
    "test:db:migration": "npx tsx tests/db/scripts/migration-test.ts",
    "test:db:health": "npx tsx tests/db/scripts/health-check.ts",
    "test:integration:docker": "docker-compose -f docker-compose.test.yml --profile integration-tests up --build --abort-on-container-exit",
    "test:supabase": "docker-compose -f docker-compose.test.yml --profile supabase-tests up --build --abort-on-container-exit",
    "validate-email-system": "node scripts/validate-email-system.js",
    "validate-email-system:live": "node scripts/validate-email-system.js --live-test",
    "test:email:all": "node scripts/run-email-tests.js",
    "test:email:preflight": "node scripts/run-email-tests.js --phase=preflight",
    "test:email:e2e": "npx playwright test tests/email/e2e-email-tests.spec.ts",
    "test:email:security": "npm test -- --testPathPattern=\"rate-limiting-security\" --testTimeout=120000",
    "security:init": "node scripts/initialize-production-security.js",
    "security:validate": "node scripts/initialize-production-security.js --validate-only",
    "security:test": "node scripts/security-ci-tests.js",
    "security:test:config": "node scripts/security-ci-tests.js --category=configurationSecurity",
    "security:test:auth": "node scripts/security-ci-tests.js --category=unitTests",
    "security:test:simple": "node scripts/security-ci-simple.js",
    "security:validate:simple": "node scripts/validate-env-simple.js",
    "security:health": "curl -s http://localhost:3000/api/security/health | jq .",
    "security:monitor": "node -e \"require('./lib/security/continuous-validation').startSecurityValidation(); console.log('Security monitoring started'); setInterval(() => {}, 1000);\"",
    "setup:env": "node scripts/setup-environment.js",
    "setup:env:interactive": "node scripts/setup-environment.js --interactive",
    "setup:env:dev": "node scripts/setup-environment.js --dev",
    "setup:env:test": "node scripts/setup-environment.js --test",
    "test:privacy:all": "vitest run tests/critical/privacy-boundary-comprehensive.test.ts",
    "test:relationships": "vitest run tests/aha-moments/multi-relationship-scenarios.test.ts",
    "test:performance": "vitest run tests/performance/reliability-scale-testing.test.ts",
    "test:scale:email": "vitest run tests/scale/email-invitation-system.test.ts",
    "test:integrity": "vitest run tests/integrity/data-consistency-recovery.test.ts",
    "test:monitoring": "npm run monitoring:check && npm run security:health",
    "test:user-journey": "npx playwright test tests/e2e/user-journey.spec.ts",
    "test:production:all": "npm run test:privacy:all && npm run test:relationships && npm run test:performance && npm run test:scale:email && npm run test:integrity && npm run test:monitoring && npm run test:user-journey",
    "error-logging:setup": "node scripts/setup-error-logging.js setup",
    "error-logging:verify": "node scripts/setup-error-logging.js verify"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.873.0",
    "@hookform/resolvers": "^3.10.0",
    "@node-rs/argon2": "^2.0.2",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-alert-dialog": "^1.1.2",
    "@radix-ui/react-aspect-ratio": "^1.1.1",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.2",
    "@radix-ui/react-collapsible": "^1.1.1",
    "@radix-ui/react-context-menu": "^2.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-hover-card": "^1.1.2",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-menubar": "^1.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.1",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-radio-group": "^1.2.1",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slider": "^1.2.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-toggle": "^1.1.1",
    "@radix-ui/react-toggle-group": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@sendgrid/mail": "^8.1.5",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.56.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^22.8.7",
    "@types/nodemailer": "^7.0.1",
    "@types/redis": "^4.0.10",
    "autoprefixer": "^10.4.21",
    "bcrypt": "^6.0.0",
    "chrono-node": "^2.8.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "countries-and-timezones": "^3.8.0",
    "critters": "npm:beasties@^0.3.0",
    "cross-env": "^10.0.0",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.1",
    "embla-carousel-react": "^8.3.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.32",
    "googleapis": "^157.0.0",
    "ical-generator": "^9.0.0",
    "idb": "^8.0.3",
    "input-otp": "^1.4.1",
    "ioredis": "^5.7.0",
    "lucide-react": "^0.446.0",
    "mem0ai": "^2.1.38",
    "moment-timezone": "^0.6.0",
    "next": "^14.2.32",
    "next-themes": "^0.3.0",
    "node-ical": "^0.20.1",
    "nodemailer": "^7.0.5",
    "openai": "^5.15.0",
    "pg": "^8.16.3",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "react-resizable-panels": "^2.1.9",
    "recharts": "^2.15.4",
    "redis": "^5.8.2",
    "resend": "^6.0.1",
    "rrule": "^2.8.1",
    "sonner": "^1.7.4",
    "spacetime": "^7.10.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^5.9.0",
    "typescript": "^5.9.2",
    "vaul": "^0.9.9",
    "vite": "^5.4.10",
    "vitest": "^3.2.4",
    "workbox-strategies": "^7.3.0",
    "workbox-webpack-plugin": "^7.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@next/bundle-analyzer": "^14.2.32",
    "@pact-foundation/pact": "^15.0.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "axe-core": "^4.10.3",
    "jsdom": "^24.1.3",
    "playwright": "^1.55.0",
    "rimraf": "^6.0.1",
    "shx": "^0.4.0",
    "supabase": "^2.39.2",
    "tsx": "^4.19.2"
  },
  "overrides": {
    "xmldom": "@xmldom/xmldom"
  }
}
