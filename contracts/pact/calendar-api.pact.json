                  "type": "string"
                }
              },
              "next_steps": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": ["integration_id", "status", "provider", "permissions_granted", "next_steps"]
          }
        }
      }
    },
