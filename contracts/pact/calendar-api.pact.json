    {
      "description": "Setup OAuth integration for external calendars",
      "providerState": "User is setting up new calendar integration",
      "request": {
        "method": "POST",
        "path": "/api/calendar/oauth/setup",
        "headers": {
          "Authorization": "Bearer valid-token",
          "Content-Type": "application/json",
          "X-CSRF-Token": "valid-csrf-token"
        },
        "body": {
          "provider": "google",
          "redirect_uri": "https://app.polyharmony.com/integrations/callback",
          "scopes": ["calendar.readonly", "calendar.events"],
          "integration_name": "Work Calendar"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json"
        },
        "body": {
          "oauth_setup": {
            "type": "object",
            "properties": {
              "authorization_url": {
                "type": "string",
                "format": "uri"
              },
              "state_token": {
                "type": "string",
                "minLength": 32
              },
              "integration_id": {
                "type": "string",
                "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
              },
              "expires_at": {
                "type": "string",
                "format": "date-time"
              },
              "required_permissions": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": ["authorization_url", "state_token", "integration_id", "expires_at", "required_permissions"]
          }
        }
      }
    },
    {
      "description": "Handle OAuth callback from external calendar provider",
      "providerState": "OAuth authorization completed successfully",
      "request": {
        "method": "GET",
        "path": "/api/calendar/oauth/callback",
        "headers": {
          "Authorization": "Bearer valid-token"
        },
        "query": {
          "code": "oauth_authorization_code",
          "state": "state_token_from_setup",
