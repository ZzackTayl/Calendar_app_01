                    "conflicting_event_id": {
                      "type": "string",
                      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
                    },
                    "conflict_type": {
                      "type": "string",
                      "enum": ["overlap", "travel_time", "back_to_back"]
                    },
                    "severity": {
                      "type": "string",
                      "enum": ["high", "medium", "low"]
                    },
                    "conflicting_event_title": {
                      "type": "string"
                    }
                  }
                }
              },
              "alternatives": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "suggested_start": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "suggested_end": {
                      "type": "string",
                      "format": "date-time"
                    },
                    "availability_score": {
                      "type": "number",
                      "minimum": 0,
                      "maximum": 1
                    },
                    "reason": {
                      "type": "string"
                    }
                  },
                  "required": ["suggested_start", "suggested_end", "availability_score", "reason"]
                }
              }
            },
            "required": ["has_conflicts", "conflict_count", "conflicts", "alternatives"]
