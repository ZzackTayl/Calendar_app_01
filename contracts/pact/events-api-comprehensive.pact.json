    {
      "description": "Get user events with privacy filtering and pagination",
      "providerState": "User has events with different privacy levels",
      "request": {
        "method": "GET",
        "path": "/api/events",
        "headers": {
          "Authorization": "Bearer valid-token",
          "Content-Type": "application/json"
        },
        "query": {
          "start_date": "2024-01-01T00:00:00Z",
          "end_date": "2024-01-31T23:59:59Z",
          "page": "1",
          "pageSize": "20"
        }
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json",
          "X-RateLimit-Remaining": "95",
          "X-RateLimit-Reset": "3600"
        },
        "body": {
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
                },
                "title": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 200
                },
                "description": {
                  "type": ["string", "null"],
                  "maxLength": 2000
                },
                "start_time": {
                  "type": "string",
                  "format": "date-time"
                },
                "end_time": {
                  "type": "string",
                  "format": "date-time"
                },
                "location": {
                  "type": ["string", "null"],
                  "maxLength": 500
                },
                "privacy_level": {
                  "type": "string",
                  "enum": ["private", "busy_only", "details", "public"]
                },
                "privacy_override": {
                  "type": ["string", "null"],
                  "enum": ["default", "private", null]
                },
                "user_id": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
                },
                "relationship_id": {
                  "type": ["string", "null"],
                  "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
                },
                "status": {
                  "type": "string",
                  "enum": ["confirmed", "tentative", "cancelled"]
                },
                "is_all_day": {
                  "type": "boolean"
                },
                "color": {
                  "type": ["string", "null"],
                  "pattern": "^#[0-9A-Fa-f]{6}$"
                },
                "recurrence_rule": {
                  "type": ["string", "null"]
                },
                "time_zone": {
                  "type": "string",
                  "minLength": 1
                },
                "created_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "updated_at": {
                  "type": "string",
                  "format": "date-time"
                }
              },
              "required": [
                "id",
                "title",
                "start_time",
                "end_time",
                "privacy_level",
                "user_id",
                "status",
                "is_all_day",
                "time_zone",
                "created_at"
              ]
            }
          },
          "pagination": {
            "type": "object",
            "properties": {
              "page": {
                "type": "integer",
                "minimum": 1
              },
              "pageSize": {
                "type": "integer",
                "minimum": 1,
                "maximum": 100
              },
              "totalPages": {
                "type": "integer",
                "minimum": 0
              },
              "totalCount": {
                "type": "integer",
                "minimum": 0
              },
              "hasNextPage": {
                "type": "boolean"
              },
              "hasPrevPage": {
                "type": "boolean"
              }
            },
            "required": [
              "page",
              "pageSize",
              "totalPages",
              "totalCount",
              "hasNextPage",
              "hasPrevPage"
            ]
          }
        }
      }
    },
