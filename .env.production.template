# =============================================================================
# PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================
# Copy this file to .env.production and fill in your production values
# NEVER commit .env.production to version control
# All variables marked as REQUIRED must be set for production deployment

# =============================================================================
# CORE APPLICATION (REQUIRED)
# =============================================================================
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_TELEMETRY_DISABLED=1

# =============================================================================
# SUPABASE DATABASE (REQUIRED)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# SECURITY & ENCRYPTION (REQUIRED - REGENERATE ALL SECRETS)
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-character-hex-encryption-key

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
KEY_DERIVATION_SECRET=your-128-character-key-derivation-secret

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your-base64-jwt-secret

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=your-base64-nextauth-secret
NEXTAUTH_URL=https://your-domain.com

# =============================================================================
# EMAIL PROVIDER (REQUIRED)
# =============================================================================
# Production email service - choose ONE provider
RESEND_API_KEY=your-resend-api-key
INVITATION_FROM_EMAIL=noreply@your-domain.com
INVITATION_FROM_NAME=Your App Name

# Alternative email providers (uncomment if using instead of Resend):
# SENDGRID_API_KEY=your-sendgrid-api-key
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_REGION=us-east-1

# =============================================================================
# GOOGLE CALENDAR INTEGRATION (OPTIONAL)
# =============================================================================
# Only required if enabling Google Calendar features
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=https://your-domain.com/api/calendar/oauth/callback

# =============================================================================
# FEATURE FLAGS (PRODUCTION SETTINGS)
# =============================================================================
FEATURE_GOOGLE_CALENDAR=false
FEATURE_EMAIL_NOTIFICATIONS=true
NEXT_PUBLIC_DEV_AUTH_BYPASS=false
ENABLE_DEBUG_LOGGING=false
SKIP_EMAIL_VERIFICATION=false

# =============================================================================
# PERFORMANCE & SECURITY (PRODUCTION OPTIMIZED)
# =============================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
LOG_LEVEL=warn

# =============================================================================
# PRODUCTION SECURITY CHECKLIST
# =============================================================================
# ✅ All secrets regenerated (never use development values)
# ✅ HTTPS URLs configured
# ✅ Rate limiting enabled
# ✅ Debug logging disabled
# ✅ Dev auth bypass disabled
# ✅ Email verification required
# ✅ Error reporting configured
# ✅ Backup and monitoring in place