# PolyHarmony Calendar - Test Environment Secrets Example
# Copy to config/testing/.env.testing.local and fill with secure values for local runs
# Secrets left blank will be generated dynamically when running scripts/tests.

TEST_DB_PASSWORD=
SUPABASE_DB_PASSWORD=
TEST_SUPABASE_URL=http://127.0.0.1:54321
TEST_SUPABASE_ANON_KEY=
TEST_SUPABASE_SERVICE_KEY=
TEST_JWT_SECRET=
TEST_ENCRYPTION_KEY=
TEST_CSRF_SECRET=
KEY_DERIVATION_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Optional overrides
TEST_DB_HOST=127.0.0.1
TEST_DB_PORT=5433
TEST_DB_NAME=polyharmony_test
TEST_DB_USER=postgres
