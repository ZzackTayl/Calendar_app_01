# Copy this file to config/production/.env.production (ignored by git) and fill in real values.
# All keys are required for both build-time validation and runtime startup.

# Supabase configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Application security
ENCRYPTION_KEY=replace-with-64-char-hexadecimal-key
JWT_SECRET=replace-with-32-plus-char-secret

# Runtime configuration
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0
NEXT_PUBLIC_APP_URL=https://app.polyharmony.app
NEXT_PUBLIC_WEB_APP_URL=https://app.polyharmony.app
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Email (production-safe defaults)
SENDGRID_API_KEY=replace-with-sendgrid-api-key
INVITATION_FROM_EMAIL=prod@polyharmony.app
INVITATION_FROM_NAME=PolyHarmony

# Feature flags / logging
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_REQUEST_LOGGING=true
LOG_LEVEL=info

# Optional: add any other secrets referenced by your entrypoint validation script.
