# PolyHarmony Calendar - Staging Environment Configuration
# This file contains all environment variables needed for the staging environment

# =================================================================
# CORE APPLICATION CONFIGURATION
# =================================================================
NODE_ENV=staging
NEXT_TELEMETRY_DISABLED=1

# Application URLs
STAGING_APP_URL=https://staging.polyharmony.app
NEXT_PUBLIC_APP_URL=https://staging.polyharmony.app
NEXT_PUBLIC_WEB_APP_URL=https://staging.polyharmony.app

# =================================================================
# DATABASE CONFIGURATION
# =================================================================
# Main application database
STAGING_DATABASE_URL=postgresql://postgres:staging_secure_password@staging-db:5432/polyharmony_staging
STAGING_DB_NAME=polyharmony_staging
STAGING_DB_USER=postgres
STAGING_DB_PASSWORD=staging_secure_password

# Database replication (if using)
STAGING_REPLICA_DATABASE_URL=postgresql://postgres:staging_secure_password@staging-db-replica:5432/polyharmony_staging

# =================================================================
# SUPABASE CONFIGURATION (STAGING)
# =================================================================
STAGING_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
STAGING_SUPABASE_ANON_KEY=your-staging-supabase-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-supabase-anon-key
STAGING_SUPABASE_SERVICE_ROLE_KEY=your-staging-supabase-service-role-key
SUPABASE_SERVICE_ROLE_KEY=your-staging-supabase-service-role-key

# =================================================================
# SECURITY CONFIGURATION
# =================================================================
# Encryption (generate with: node scripts/generate-encryption-key.js)
STAGING_ENCRYPTION_KEY=your-64-character-hex-staging-encryption-key-here-replace-this-example
ENCRYPTION_KEY=your-64-character-hex-staging-encryption-key-here-replace-this-example

# JWT Secret (32+ characters)
STAGING_JWT_SECRET=your-staging-jwt-secret-key-32-characters-minimum-length
JWT_SECRET=your-staging-jwt-secret-key-32-characters-minimum-length

# Session configuration
SESSION_SECRET=your-staging-session-secret-32-characters-minimum

# =================================================================
# EMAIL CONFIGURATION (STAGING)
# =================================================================
# Use separate staging email service/API keys
STAGING_SENDGRID_API_KEY=your-staging-sendgrid-api-key
SENDGRID_API_KEY=your-staging-sendgrid-api-key

# Or use alternative email service for staging
STAGING_RESEND_API_KEY=your-staging-resend-api-key
RESEND_API_KEY=your-staging-resend-api-key

# Email sender configuration
STAGING_FROM_EMAIL=staging@polyharmony.app
INVITATION_FROM_EMAIL=staging@polyharmony.app
INVITATION_FROM_NAME=PolyHarmony Staging

# =================================================================
# CALENDAR INTEGRATIONS (STAGING)
# =================================================================
# Use staging/sandbox credentials for external services
GOOGLE_CLIENT_ID=your-staging-google-client-id
GOOGLE_CLIENT_SECRET=your-staging-google-client-secret

# Apple Calendar (staging)
APPLE_CLIENT_ID=your-staging-apple-client-id
APPLE_CLIENT_SECRET=your-staging-apple-client-secret

# =================================================================
# RATE LIMITING (MORE PERMISSIVE FOR TESTING)
# =================================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=200
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# API-specific rate limits (more permissive)
API_RATE_LIMIT_WINDOW=60000
API_RATE_LIMIT_MAX=150
UPLOAD_RATE_LIMIT_MAX=50
EMAIL_RATE_LIMIT_MAX=20

# =================================================================
# REDIS CONFIGURATION (CACHING & SESSIONS)
# =================================================================
REDIS_URL=redis://redis-staging:6379
REDIS_HOST=redis-staging
REDIS_PORT=6379
REDIS_PASSWORD=staging_redis_password

# Session storage
SESSION_STORE=redis
SESSION_REDIS_URL=redis://redis-staging:6379

# =================================================================
# MONITORING & LOGGING
# =================================================================
# Enable comprehensive logging for staging
LOG_LEVEL=debug
ENABLE_REQUEST_LOGGING=true
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_ERROR_TRACKING=true

# External monitoring services (staging endpoints)
SENTRY_DSN=your-staging-sentry-dsn
NEW_RELIC_LICENSE_KEY=your-staging-newrelic-key

# =================================================================
# SSL/TLS CONFIGURATION
# =================================================================
# Let's Encrypt configuration for staging SSL
ACME_EMAIL=admin@polyharmony.app
SSL_CERT_PATH=/letsencrypt
ENABLE_HTTPS_REDIRECT=true

# =================================================================
# BACKUP CONFIGURATION
# =================================================================
# Automated backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=polyharmony-staging-backups
BACKUP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-staging-aws-access-key
AWS_SECRET_ACCESS_KEY=your-staging-aws-secret-key

# =================================================================
# DEPLOYMENT CONFIGURATION
# =================================================================
# Blue-green deployment
DEPLOYMENT_COLOR=blue
ENABLE_CANARY_DEPLOYMENT=true
CANARY_TRAFFIC_PERCENTAGE=10

# Health checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/api/health
HEALTH_CHECK_TIMEOUT=30000

# =================================================================
# FEATURE FLAGS (STAGING)
# =================================================================
# Enable experimental features in staging
ENABLE_EXPERIMENTAL_FEATURES=true
ENABLE_DEBUG_FEATURES=true
ENABLE_PERFORMANCE_PROFILING=true

# Testing flags
ENABLE_TEST_MODE=true
MOCK_EXTERNAL_SERVICES=false
DISABLE_RATE_LIMITING_FOR_TESTS=false

# =================================================================
# DATA SANITIZATION
# =================================================================
# Control data sanitization for staging
SANITIZATION_MODE=staging
SANITIZE_ON_STARTUP=false
PRESERVE_TEST_USERS=true

# =================================================================
# MOBILE APP CONFIGURATION
# =================================================================
NEXT_PUBLIC_APP_SCHEME=polyharmony-staging
NEXT_PUBLIC_MOBILE_APP_URL=polyharmony-staging://

# =================================================================
# ANALYTICS (STAGING)
# =================================================================
# Use staging/test analytics configurations
GOOGLE_ANALYTICS_ID=your-staging-ga-id
MIXPANEL_TOKEN=your-staging-mixpanel-token

# =================================================================
# CDN & ASSET CONFIGURATION
# =================================================================
# Use staging CDN endpoints
CDN_URL=https://staging-cdn.polyharmony.app
ASSET_PREFIX=https://staging-cdn.polyharmony.app

# =================================================================
# WEBHOOK CONFIGURATION
# =================================================================
# Staging webhook endpoints
WEBHOOK_SECRET=your-staging-webhook-secret
WEBHOOK_BASE_URL=https://staging.polyharmony.app/api/webhooks

# =================================================================
# GRAFANA & MONITORING
# =================================================================
GRAFANA_ADMIN_PASSWORD=staging_grafana_admin_secure_123

# Prometheus metrics
ENABLE_METRICS=true
METRICS_PATH=/metrics
METRICS_PORT=9090

# =================================================================
# DEVELOPMENT & DEBUGGING (STAGING ONLY)
# =================================================================
# Enable additional debugging in staging
DEBUG_MODE=true
VERBOSE_LOGGING=true
ENABLE_QUERY_LOGGING=true
ENABLE_PERFORMANCE_TRACES=true

# API documentation
ENABLE_API_DOCS=true
API_DOCS_PASSWORD=staging_docs_password_123