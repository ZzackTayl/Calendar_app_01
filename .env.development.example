# Development Environment Configuration
# Copy this to .env.local for local development
# This file contains only the essential variables needed for development

# =============================================================================
# SECURITY PROFILE CONFIGURATION
# =============================================================================

# Security profile for runtime configuration
# Options: production, staging, development, demo
SECURITY_PROFILE=development

# Development mode settings (automatically detected)
NODE_ENV=development

# =============================================================================
# CORE APPLICATION CONFIGURATION
# =============================================================================

# Application URL for development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Supabase Configuration (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# JWT Secret for token validation (generate with: openssl rand -hex 32)
JWT_SECRET=your_64_character_jwt_secret_here

# Encryption key for sensitive data (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=your_64_character_hex_encryption_key_here

# CSRF Protection Mode (strict, relaxed, disabled)
CSRF_MODE=relaxed

# Development auth bypass (NEVER set to true in production)
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# =============================================================================
# PERFORMANCE OPTIMIZATION SETTINGS
# =============================================================================

# Enable middleware performance optimizations
ENABLE_MIDDLEWARE_OPTIMIZATIONS=true

# Reduce middleware logging for better performance
MINIMAL_MIDDLEWARE_LOGS=true

# Skip development security headers for faster loading
SKIP_DEV_SECURITY_HEADERS=true

# Enable middleware caching
ENABLE_MIDDLEWARE_CACHE=true

# =============================================================================
# RATE LIMITING CONFIGURATION (Development-friendly)
# =============================================================================

# Auth rate limiting (window in minutes, max attempts)
RATE_LIMIT_AUTH_WINDOW=5
RATE_LIMIT_AUTH_MAX=20

# API rate limiting (window in seconds, max requests)
RATE_LIMIT_API_WINDOW=60
RATE_LIMIT_API_MAX=500

# =============================================================================
# SESSION CONFIGURATION
# =============================================================================

# Session TTL in seconds (4 hours for development)
SESSION_TTL=14400

# Session cache TTL in seconds (1 minute for development)
SESSION_CACHE_TTL=60

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=debug

# Disable analytics in development
DISABLE_ANALYTICS=true

# =============================================================================
# PWA CONFIGURATION
# =============================================================================

# Disable PWA in development to avoid caching issues
PWA_ENABLED=false

# =============================================================================
# EMAIL CONFIGURATION (Optional - for testing email features)
# =============================================================================

# Choose ONE email provider for development testing:

# Option 1: Resend (recommended for development)
# RESEND_API_KEY=your_resend_api_key

# Option 2: SMTP (for local testing with services like MailHog)
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=

# Email sender configuration
INVITATION_FROM_EMAIL=dev@localhost
INVITATION_FROM_NAME=PolyHarmony Dev

# =============================================================================
# DEMO MODE (Optional)
# =============================================================================

# Enable demo mode for offline development
# DEMO_MODE=false
# NEXT_PUBLIC_DEMO_MODE=false

# =============================================================================
# DEVELOPMENT HELPERS
# =============================================================================

# Skip runtime autostart during build
RUNTIME_SKIP_AUTOSTART=1

# =============================================================================
# END OF ESSENTIAL DEVELOPMENT CONFIGURATION
# =============================================================================

# Total variables: 26 essential variables for development
# This represents a 80%+ reduction from the full production configuration
# while maintaining all functionality needed for local development
