{
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore",
  // Optional: helps VS Code understand Tailwind better
  "editor.quickSuggestions": {
    "strings": true
  },
  // Docs hygiene: prefer canonical docs in /docs with short root pointers
  "files.associations": {
    "SETUP_GUIDE.md": "markdown"
  },
  "markdownlint.config": {
    "MD041": false
  }
}