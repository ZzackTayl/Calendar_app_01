[sqlfluff]
dialect = postgres
templater = jinja

[sqlfluff:rules]
# Disable rules that conflict with PostgreSQL syntax
L010 = False  # Keywords should be consistently upper case
L030 = False  # Function names should be consistently upper case
L031 = False  # Avoid table aliases in from clauses and join conditions
L032 = False  # Prefer AS to explicit aliasing
L033 = False  # Unnecessary quoted identifier
L034 = False  # Use wildcards then simple columns in select statements
L035 = False  # Do not specify "else null" in a case when statement (redundant)
L036 = False  # Select targets should be on a new line unless there is only one select target
L037 = False  # Ambiguous column references in ORDER BY clause
L038 = False  # Unnecessary trailing whitespace
L039 = False  # Unnecessary whitespace
L040 = False  # Null values should not be used in boolean comparisons
L041 = False  # Unnecessary table aliases
L042 = False  # Join/From clauses should not contain subqueries. Use CTEs instead
L043 = False  # Unnecessary CASE statement
L044 = False  # Query defines a CTE (Common Table Expression) but does not use it
L045 = False  # Query defines a CTE (Common Table Expression) but does not use it
L046 = False  # Jinja tags should have a single whitespace on either side
L047 = False  # Use consistent syntax to express "count number of rows"
L048 = False  # Quoted literals should be placed on a single line
L049 = False  # Unnecessary GROUP BY clause
L050 = False  # Files should not end with a trailing newline
L051 = False  # JOIN clause should be fully qualified
L052 = False  # Statements must end with a semicolon
L053 = False  # Table aliases should be unique within each clause
L054 = False  # Inconsistent column references in GROUP BY clause
L055 = False  # Use LEFT JOIN instead of RIGHT JOIN
L056 = False  # Use 'COALESCE' instead of 'IFNULL' or 'NVL'
L057 = False  # Do not use 'DISTINCT' in a COUNT
L058 = False  # Statement contains trailing whitespace
L059 = False  # Unnecessary table aliases in UPDATE
L060 = False  # Use 'IS' instead of '=' when comparing to NULL
L061 = False  # Use 'IS NOT' instead of '!=' when comparing to NULL
L062:blocked_words = password,pass,passwd,pwd,secret,token,key
L063 = False  # Unnecessary table aliases in DELETE
L064 = False  # Inconsistent spacing in 'IS NULL' construct
L065 = False  # Set operators should be surrounded by newlines
L066 = False  # Order by clause should not contain ordinal references
L067 = False  # Enforce single space in 'IS NULL' construct
L068 = False  # Quoted identifiers should not be used
L069 = False  # Functions should not be used in check constraints
L070 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L071 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L072 = False  # References should be qualified if select has more than one referenced table or view
L073 = False  # Use 'COALESCE' instead of 'IFNULL' or 'NVL'
L074 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L075 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L076 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L077 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L078 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L079 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L080 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L081 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L082 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L083 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L084 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L085 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L086 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L087 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L088 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L089 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L090 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L091 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L092 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L093 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L094 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
L095 = False  # Use 'IS NOT DISTINCT FROM' instead of 'IS' when comparing to NULL
L096 = False  # Use 'IS DISTINCT FROM' instead of 'IS NOT' when comparing to NULL
