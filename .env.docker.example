# PolyHarmony Calendar - Docker Environment Template
# Copy this to .env.local for development or .env.production for production

# ==============================================
# CRITICAL PRODUCTION VARIABLES
# ==============================================

# Node Environment (development, staging, production)
NODE_ENV=production

# Application URLs
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_WEB_APP_URL=https://your-domain.com

# ==============================================
# DATABASE CONFIGURATION
# ==============================================

# Supabase Configuration (REQUIRED)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# PostgreSQL Direct Connection (if using external DB)
DATABASE_URL=postgresql://user:password@host:5432/database

# ==============================================
# SECURITY CONFIGURATION (CRITICAL)
# ==============================================

# Encryption Key (MUST be 64 characters - generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_64_character_encryption_key_here

# JWT Secret for NextAuth (REQUIRED in production)
NEXTAUTH_SECRET=your_nextauth_secret_here

# ==============================================
# EMAIL CONFIGURATION
# ==============================================

# Email Provider (resend, sendgrid, aws_ses, smtp, console)
EMAIL_PROVIDER=resend

# Resend Configuration
RESEND_API_KEY=your_resend_api_key

# SendGrid Configuration (alternative)
SENDGRID_API_KEY=your_sendgrid_api_key

# SMTP Configuration (alternative)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Email Sender Information
INVITATION_FROM_EMAIL=noreply@your-domain.com
INVITATION_FROM_NAME=PolyHarmony Calendar

# ==============================================
# PERFORMANCE & MONITORING
# ==============================================

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Performance Monitoring
ENABLE_PERFORMANCE_MONITORING=true
LOG_LEVEL=info

# ==============================================
# OPTIONAL FEATURES
# ==============================================

# Demo Mode (NEVER enable in production)
ENABLE_DEMO_MODE=false

# Development Auth Bypass (NEVER enable in production)
NEXT_PUBLIC_DEV_AUTH_BYPASS=false

# Analytics
NEXT_PUBLIC_ANALYTICS_ID=your_analytics_id

# Sentry Error Tracking
SENTRY_DSN=your_sentry_dsn

# ==============================================
# DOCKER-SPECIFIC CONFIGURATION
# ==============================================

# Container Timezone
TZ=UTC

# Application Port (internal container port)
PORT=3000

# Container Hostname
HOSTNAME=0.0.0.0

# Health Check Configuration
HEALTH_CHECK_INTERVAL=30s
HEALTH_CHECK_TIMEOUT=10s
HEALTH_CHECK_RETRIES=3

# ==============================================
# PRODUCTION DEPLOYMENT
# ==============================================

# SSL Configuration
SSL_ENABLED=true
FORCE_HTTPS=true

# ACME Email for Let's Encrypt
ACME_EMAIL=admin@your-domain.com

# Deployment Environment
DEPLOYMENT_ENVIRONMENT=production
